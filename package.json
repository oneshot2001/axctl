{
  "name": "axctl",
  "version": "0.1.0",
  "description": "Axis camera analytics CLI — configure AOA, stream events, discover devices",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "bin": {
    "axctl": "src/index.ts"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile axctl",
    "build:all": "bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:linux-arm64 && bun run build:linux-x64",
    "build:macos-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/axctl-macos-arm64",
    "build:macos-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/axctl-macos-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/axctl-linux-arm64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/axctl-linux-x64",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "typescript": "^5"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "js-yaml": "^4.1.1",
    "mqtt": "^5.15.0"
  }
}
